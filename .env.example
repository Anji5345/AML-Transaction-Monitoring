# Copy this file to .env locally or paste these values into PowerShell.
# Never commit real SMTP passwords.

EMAIL_ENABLED=true
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURITY=starttls
SMTP_USE_TLS=true
SMTP_USERNAME=YOUR_MAILTRAP_USERNAME
SMTP_PASSWORD=YOUR_MAILTRAP_PASSWORD
EMAIL_FROM=aml-monitoring@example.com
EMAIL_TO=aml-analyst@example.com
HIGH_RISK_THRESHOLD=85

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=amldb
POSTGRES_USER=amluser
POSTGRES_PASSWORD=amlpass

KAFKA_ALERT_TOPIC=aml.alerts
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
